import random

def roll():
    """Return a random dice roll between 1 and 6."""
    return random.randint(1, 6)

def get_int(prompt: str, min_val: int, max_val: int) -> int:
    """Prompt the user for an integer within a range, retrying until valid."""
    while True:
        try:
            val = int(input(prompt))
        except ValueError:
            print("Invalid input. Enter an integer.")
            continue
        if val < min_val or val > max_val:
            print(f"Please enter a number between {min_val} and {max_val}.")
            continue
        return val

def main():
    players = get_int("Enter the number of players (2-4): ", 2, 4)
    max_score = get_int("Enter the maximum score to win: ", 1, 10000)

    scores = [0] * players
    current_player = 0

    while True:
        print(f"\nPlayer {current_player + 1}'s turn. Current score: {scores[current_player]}")
        turn_score = 0
        while True:
            should_roll = input("Do you want to roll the dice? (yes/no): ").strip().lower()
            if should_roll not in ("yes", "y"):
                print("Turn ended.")
                break

            value = roll()
            if value == 1:
                print("You rolled a 1! Turn score resets to 0.")
                turn_score = 0
                break
            else:
                turn_score += value
                print(f"You rolled a {value}. Turn total: {turn_score}.")
                if scores[current_player] + turn_score >= max_score:
                    scores[current_player] += turn_score
                    print(f"Player {current_player + 1} wins with a score of {scores[current_player]}!")
                    return
        scores[current_player] += turn_score
        current_player = (current_player + 1) % players

if __name__ == "__main__":
    main()